---
import Header from '../components/Header.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import ClientRouter from 'astro/components/ClientRouter.astro';

interface Props {
  title?: string;
}

const { title = "Romain Missoum - Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="Portfolio de Romain Missoum, développeur et étudiant en informatique" />
		<title>{title}</title>
		<link rel="icon" type="image/svg+xml" href="./favicon.svg" />
		<link rel="icon" href="./favicon.ico" />
		<ClientRouter />
	</head>
	<body>
		<Navigation />
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
		<button id="cat-trigger" class="cat-trigger" type="button" aria-label="Activer le mode chat secret">cat</button>
		<div id="cat-warning" class="cat-warning" hidden>Cat flood incoming...</div>
		<div id="cat-flood-layer" class="cat-flood-layer" aria-hidden="true"></div>
	</body>
</html>

<style is:global>
	:root {
		--primary: #1e40af;
		--secondary: #10b981;
		--surface-1: #f4f7fb;
		--surface-2: #ffffff;
		--text-1: #0f172a;
		--text-2: #334155;
		--accent: #2563eb;
		--accent-soft: #dbeafe;
		--border: #dbe3ee;
		/* Couleurs pour fonds sombres (Header, Nav, Footer, cards glassmorphism) */
		--dk-text: #e2e8f0;       /* texte principal sur fond sombre — 15:1 sur #0f172a */
		--dk-muted: #94a3b8;      /* texte secondaire sur fond sombre — 7:1 sur #0f172a */
		--dk-accent: #93c5fd;     /* bleu clair sur fond sombre — 8:1 sur #1f2937 */
		--dk-green: #6ee7b7;      /* vert clair sur fond sombre — 9:1 sur #1f2937 */
		--cat-width: 128px;
		--cat-height: 72px;
		--start-x: 0px;
		--start-y: 0px;
		--target-x: 0px;
		--target-y: 0px;
		--start-rotation: 0deg;
		--target-rotation: 0deg;
		--leave-rotation: 0deg;
		--cat-wallpaper: none;
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html {
		font-family: Inter, "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
		scroll-behavior: smooth;
	}

	body {
		background:
			radial-gradient(circle at 15% 15%, #dbeafe 0, transparent 42%),
			radial-gradient(circle at 85% 5%, #e2e8f0 0, transparent 35%),
			linear-gradient(180deg, #f7f9fc 0%, #edf2f7 100%);
		color: var(--text-1);
		line-height: 1.6;
		min-height: 100vh;
		transition: background 0.5s ease, color 0.5s ease;
	}

	main {
		min-height: calc(100vh - 260px);
		padding: 32px 0 48px;
	}

	a {
		color: var(--accent);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	a:hover {
		color: var(--accent);
	}

	h1 {
		color: var(--text-2);
		font-size: clamp(2rem, 4vw, 3.2rem);
		letter-spacing: -0.04em;
	}

	h2 {
		text-align: center;
		margin: 48px 0 28px;
		font-size: clamp(1.7rem, 3vw, 2.4rem);
		color: #0f172a;
		position: relative;
		padding-bottom: 14px;
	}

	h2::after {
		content: "";
		position: absolute;
		bottom: 0;
		left: 50%;
		transform: translateX(-50%);
		width: 84px;
		height: 2px;
		background: linear-gradient(90deg, transparent, var(--accent), transparent);
	}

	h3 {
		color: #0f172a;
	}

	.container {
		width: min(1100px, 88%);
		margin: 0 auto;
	}

	main section > div,
	main section > article,
	main section > ul,
	main section > p,
	main section > form {
		background: var(--surface-2);
		border: 1px solid var(--border);
		border-radius: 14px;
	}

	.cat-trigger {
		position: fixed;
		right: 10px;
		bottom: 10px;
		z-index: 1500;
		width: 22px;
		height: 22px;
		border: 1px solid rgba(30, 64, 175, 0.5);
		background: rgba(30, 64, 175, 0.2);
		color: var(--primary);
		font-size: 10px;
		border-radius: 999px;
		opacity: 0.5;
		cursor: pointer;
		transition: opacity 0.2s ease, transform 0.2s ease;
	}

	.cat-trigger:hover,
	.cat-trigger:focus-visible {
		opacity: 1;
		transform: scale(1.08);
	}

	.cat-trigger:focus-visible {
		outline: 2px solid var(--primary);
		outline-offset: 2px;
	}

	.cat-trigger:disabled {
		cursor: wait;
		opacity: 0.25;
	}

	.cat-warning {
		position: fixed;
		top: 20px;
		left: 50%;
		transform: translateX(-50%);
		z-index: 1700;
		padding: 10px 16px;
		border-radius: 999px;
		background: #111827;
		color: #f8fafc;
		font-size: 0.95rem;
		letter-spacing: 0.02em;
		border: 1px solid #1f2937;
		box-shadow: 0 12px 36px rgba(15, 23, 42, 0.35);
	}

	.cat-flood-layer {
		position: fixed;
		inset: 0;
		z-index: 1600;
		pointer-events: none;
		overflow: hidden;
	}

	.cat-card {
		position: absolute;
		--cat-width: 128px;
		--cat-height: 72px;
		--start-x: 0px;
		--start-y: 0px;
		--target-x: 0px;
		--target-y: 0px;
		--start-rotation: 0deg;
		--target-rotation: 0deg;
		--leave-rotation: 0deg;
		width: var(--cat-width);
		height: var(--cat-height);
		border-radius: 10px;
		object-fit: cover;
		border: 1px solid rgba(15, 23, 42, 0.2);
		box-shadow: 0 10px 22px rgba(2, 6, 23, 0.3);
		transform: translate3d(var(--start-x), var(--start-y), 0) rotate(var(--start-rotation));
		transition:
			transform 0.8s cubic-bezier(0.22, 1, 0.36, 1),
			filter 0.3s ease;
	}

	.cat-card.landing {
		transform: translate3d(var(--target-x), var(--target-y), 0) rotate(var(--target-rotation));
	}

	.cat-card.leaving {
		transform: translate3d(var(--target-x), calc(110vh + var(--cat-height)), 0) rotate(var(--leave-rotation));
		transition:
			transform 0.7s ease-in,
			filter 0.25s ease;
		filter: blur(1px);
	}

	body.cat-theme {
		--surface-2: rgba(253, 244, 228, 0.95);
		--surface-1: #fff7ed;
		--text-1: #422006;
		--text-2: #7c2d12;
		--accent: #b45309;
		--accent-soft: #fed7aa;
		--border: rgba(180, 83, 9, 0.35);
		--cat-wallpaper: url('data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==');
	}

	body.cat-theme::before {
		content: "";
		position: fixed;
		inset: 0;
		z-index: -1;
		opacity: 0.16;
		background-image: var(--cat-wallpaper);
		background-size: 240px 135px;
		background-repeat: repeat;
		pointer-events: none;
	}

	@keyframes fadeIn {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	main > section {
		animation: fadeIn 0.45s ease forwards;
	}

	main > section:nth-child(2) {
		animation-delay: 0.1s;
	}

	main > section:nth-child(3) {
		animation-delay: 0.2s;
	}

	@media (max-width: 768px) {
		h2 {
			margin: 34px 0 24px;
		}

		.cat-warning {
			width: calc(100% - 24px);
			text-align: center;
		}

		main {
			padding: 20px 0 32px;
		}
	}
</style>

<script is:inline>
(function initCat() {
	const trigger     = document.getElementById("cat-trigger");
	const warning     = document.getElementById("cat-warning");
	const floodLayer  = document.getElementById("cat-flood-layer");
	const body        = document.body;
	if (!trigger || !warning || !floodLayer) return;

	// ── Faits sur les chats ─────────────────────────────────────────
	const catFacts = [
		"🐱 Les chats passent 70% de leur vie à dormir.",
		"🐱 Un chat peut sauter 6 fois sa hauteur.",
		"🐱 Les chats ont 32 muscles dans chaque oreille.",
		"🐱 Un groupe de chats s'appelle une 'clowder'.",
		"🐱 Les chats font ronronner à ~25Hz — fréquence de guérison osseuse.",
		"🐱 Le chat le plus vieux jamais enregistré avait 38 ans.",
		"🐱 Les chats ne peuvent pas goûter le sucré.",
		"🐱 Chaque chat a un nez unique comme les empreintes digitales.",
		"🐱 Les chats boivent en repliant leur langue en forme de J.",
		"🐱 Un chat a un champ de vision de 200°.",
	];
	const randomFact = () => catFacts[Math.floor(Math.random() * catFacts.length)];

	// ── Compteur persistant ─────────────────────────────────────────
	var catCount = parseInt(localStorage.getItem("catFloodCount") || "0", 10);
	if (catCount >= 3) trigger.textContent = "🐾";

	// ── Flood ───────────────────────────────────────────────────────
	var floodRunning = false;

	const catApi = () =>
		"https://cataas.com/cat?width=640&height=360&fit=cover&v=" + Math.floor(Math.random() * 1000000);

	const getGrid = (intensity) => {
		const gap = 10;
		const ratio = 640 / 360;
		const catWidth  = Math.max(128, Math.min(220, Math.floor(window.innerWidth / 5.2)));
		const catHeight = Math.round(catWidth / ratio);
		// intensity: 0.5 = moitié, 1 = normal, 1.5 = mega
		const cols = Math.max(1, Math.ceil(window.innerWidth  / (catWidth  + gap) * Math.min(intensity, 1)));
		const rows = Math.max(1, Math.ceil(window.innerHeight / (catHeight + gap) * Math.min(intensity, 1)));
		const extraCols = intensity > 1 ? Math.ceil(cols * (intensity - 1)) : 0;
		const extraRows = intensity > 1 ? Math.ceil(rows * (intensity - 1)) : 0;
		const totalCols = cols + extraCols;
		const totalRows = rows + extraRows;
		const usedWidth  = totalCols * catWidth  + (totalCols - 1) * gap;
		const usedHeight = totalRows * catHeight + (totalRows - 1) * gap;
		return {
			cols: totalCols, rows: totalRows, gap, catWidth, catHeight,
			offsetX: Math.max(0, Math.floor((window.innerWidth  - usedWidth)  / 2)),
			offsetY: Math.max(0, Math.floor((window.innerHeight - usedHeight) / 2)),
		};
	};

	const preloadImage = (url) =>
		new Promise((resolve) => {
			const img = new Image();
			img.onload = img.onerror = () => resolve(url);
			img.src = url;
		});

	const buildCatCard = async (index, grid) => {
		const row = Math.floor(index / grid.cols);
		const col = index % grid.cols;
		const targetX = grid.offsetX + col * (grid.catWidth + grid.gap);
		const targetY = grid.offsetY + row * (grid.catHeight + grid.gap);
		const startX  = targetX + (Math.random() * 90 - 45);
		const startY  = -1 * (150 + Math.random() * 450);
		const imageUrl = catApi();
		await preloadImage(imageUrl);
		const card = document.createElement("img");
		card.className = "cat-card";
		card.alt = "";
		card.src = imageUrl;
		card.style.setProperty("--cat-width",        grid.catWidth  + "px");
		card.style.setProperty("--cat-height",       grid.catHeight + "px");
		card.style.setProperty("--start-x",          startX + "px");
		card.style.setProperty("--start-y",          startY + "px");
		card.style.setProperty("--target-x",         targetX + "px");
		card.style.setProperty("--target-y",         targetY + "px");
		card.style.setProperty("--start-rotation",   (Math.random() * 14 - 7)  + "deg");
		card.style.setProperty("--target-rotation",  (Math.random() * 8  - 4)  + "deg");
		card.style.setProperty("--leave-rotation",   (Math.random() * 18 - 9)  + "deg");
		card.style.transitionDelay = (row * 35 + col * 14) + "ms";
		// Bounce au clic pendant le flood
		card.addEventListener("click", function() {
			this.style.transform = "scale(1.15)";
			setTimeout(() => { this.style.transform = ""; }, 200);
		});
		return card;
	};

	const runCatFlood = async () => {
		if (floodRunning) return;
		floodRunning = true;
		trigger.disabled = true;

					// Intensité selon le nombre de fois joué
					catCount++;
					localStorage.setItem("catFloodCount", catCount);

					// Si on atteint la 4ème activation, ouvrir la page chat au lieu du flood
					if (catCount >= 4) {
					  // conserver le compteur et rediriger
					  localStorage.setItem("catFloodCount", String(catCount));
					  // légère animation/retour visuel avant nav
					  warning.hidden = false;
					  warning.textContent = "Ouvrir le chat secret...";
					  setTimeout(() => { window.location.href = '/chat'; }, 450);
					  return;
					}

					const intensity = catCount === 1 ? 0.55 : catCount === 2 ? 1 : 1.4;
					const label     = catCount === 1 ? "Cat flood incoming..." : catCount === 2 ? "Cat flood x2 !!" : "🚨 MEGA CAT FLOOD 🚨";

		warning.hidden = false;
		warning.textContent = label;
		floodLayer.replaceChildren();

		const grid  = getGrid(intensity);
		const count = grid.rows * grid.cols;
		const cards = await Promise.all(
			Array.from({ length: count }, (_, i) => buildCatCard(i, grid))
		);
		if (!floodRunning) return;

		floodLayer.replaceChildren(...cards);
		requestAnimationFrame(() => {
			for (const card of cards) card.classList.add("landing");
		});

		const maxDelay   = (grid.rows - 1) * 35 + (grid.cols - 1) * 14;
		const landTime   = 820 + maxDelay;
		const restTime   = 2800;

		setTimeout(() => {
			// Afficher un fait de chat pendant le repos
			warning.textContent = randomFact();
			body.classList.add("cat-theme");
			body.style.setProperty("--cat-wallpaper", 'url("' + catApi() + '")');
			for (const card of cards) { card.classList.remove("landing"); card.classList.add("landed"); }
			if (catCount >= 3) trigger.textContent = "🐾";
		}, landTime);

		setTimeout(() => {
			for (const card of cards) card.classList.add("leaving");
		}, landTime + restTime);

		setTimeout(() => {
			floodLayer.replaceChildren();
			body.classList.remove("cat-theme");
			warning.hidden = true;
			trigger.disabled = false;
			floodRunning = false;
		}, landTime + restTime + 1000);
	};

	trigger.addEventListener("click", runCatFlood);

	// ── Konami Code ─────────────────────────────────────────────────
	var konamiSeq = [];
	var konamiCode = [38,38,40,40,37,39,37,39,66,65]; // ↑↑↓↓←→←→BA
	document.addEventListener("keydown", function(e) {
		konamiSeq.push(e.keyCode);
		if (konamiSeq.length > konamiCode.length) konamiSeq.shift();
		if (konamiSeq.join(",") === konamiCode.join(",")) {
			konamiSeq = [];
			runCatFlood();
		}
	});
})();
</script>
