---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact - Romain Missoum">
	<section class="container contact-section">
		<h2>Me contacter</h2>

		<div class="contact-content">
						<div class="contact-intro">
						<p>Pour un projet, une collaboration ou pour échanger — n'hésitez pas. Je réponds probablement.</p>
						</div>

			<div class="contact-methods">
				<div class="contact-card linkedin">
					<div class="contact-icon">
						<svg viewBox="0 0 24 24" fill="currentColor">
							<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/>
						</svg>
					</div>
					<h3>LinkedIn</h3>
					<p>Connectons-nous pour discuter de projets et d'opportunités</p>
					<a href="https://fr.linkedin.com/in/romain-missoum-9ba32a339" target="_blank" class="contact-link">
						Visiter mon profil →
					</a>
				</div>

				<div class="contact-card email">
					<div class="contact-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<rect x="2" y="4" width="20" height="16" rx="2"/>
							<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
						</svg>
					</div>
					<h3>Email</h3>
					<p>Pour des demandes directes et des propositions</p>
					<a href="mailto:romain.missoum@etu.univ-grenoble-alpes.fr" class="contact-link">
						romain.missoum[at]etu.univ-grenoble-alpes.fr
					</a>
				</div>

				<div class="contact-card github">
					<div class="contact-icon">
						<svg viewBox="0 0 24 24" fill="currentColor">
							<path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
						</svg>
					</div>
					<h3>GitHub</h3>
					<p>Retrouvez mes projets et contributions open source</p>
					<a href="https://github.com/Romain1M" target="_blank" class="contact-link">
						Voir mon profil →
					</a>
				</div>
			</div>
			<div class="quick-info">
			<h3>Informations Rapides</h3>
			<div class="info-grid">
				<div class="info-item">
					<span class="label">Âge:</span>
					<span class="value">20 ans</span>
				</div>
				<div class="info-item">
					<span class="label">Formation:</span>
					<span class="value">BUT Informatique — IUT2 UGA</span>
				</div>
				<div class="info-item">
					<span class="label">Spécialité:</span>
					<span class="value">Développement d'Applications</span>
				</div>
				<div class="info-item">
					<span class="label">Langues:</span>
					<span class="value">Français, Anglais (C1)</span>
				</div>
			</div>
		</div>
		</div>
	</section>
</Layout>

<style>
	.contact-section {
		margin-bottom: 60px;
	}

	.contact-intro {
		text-align: center;
		max-width: 700px;
		margin: 0 auto 50px;
		font-size: 1.15em;
		color: var(--text-2);
		line-height: 1.8;
	}

	.contact-methods {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 30px;
		margin-bottom: 60px;
	}

	.contact-card {
		background: rgba(31, 41, 55, 0.8);
		padding: 35px;
		border-radius: 12px;
		border: 1px solid rgba(30, 64, 175, 0.3);
		text-align: center;
		transition: all 0.3s ease;
		backdrop-filter: blur(10px);
	}

	.contact-card:hover {
		border-color: var(--primary);
		transform: translateY(-10px);
		box-shadow: 0 15px 40px rgba(30, 64, 175, 0.25);
	}

	.contact-icon {
		width: 70px;
		height: 70px;
		margin: 0 auto 20px;
		background: linear-gradient(135deg, var(--primary), var(--secondary));
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #ffffff;
		font-weight: bold;
	}

	.contact-icon svg {
		width: 35px;
		height: 35px;
	}

	.contact-card h3 {
		font-size: 1.4em;
		margin-bottom: 10px;
		color: var(--primary);
	}

	.contact-card p {
		color: var(--text-2);
		margin-bottom: 20px;
		line-height: 1.6;
	}

	.contact-link {
		display: inline-block;
		padding: 12px 25px;
		background: linear-gradient(135deg, var(--primary), var(--secondary));
		color: #ffffff;
		border-radius: 6px;
		font-weight: 500;
		transition: all 0.3s ease;
		text-decoration: none;
	}

	.contact-link:hover {
		transform: scale(1.05);
		box-shadow: 0 8px 20px rgba(30, 64, 175, 0.4);
	}

	.linkedin {
		border-top: 3px solid #0077b5;
	}

	.email {
		border-top: 3px solid #dc2626;
	}

	.github {
		border-top: 3px solid #10b981;
	}

	.quick-info {
		background: linear-gradient(135deg, rgba(30, 64, 175, 0.1) 0%, rgba(16, 185, 129, 0.05) 100%);
		padding: 35px;
		border-radius: 12px;
		border: 2px solid rgba(30, 64, 175, 0.3);
		max-width: 700px;
		margin: 0 auto;
	}

	.quick-info h3 {
		text-align: center;
		margin-bottom: 25px;
		font-size: 1.3em;
		color: var(--primary);
	}

	.info-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 20px;
	}

	.info-item {
		background: rgba(30, 64, 175, 0.1);
		padding: 15px;
		border-radius: 8px;
		border-left: 3px solid var(--primary);
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.info-item .label {
		color: var(--primary);
		font-weight: 600;
		font-size: 0.9em;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.info-item .value {
		color: var(--text-2);
		font-size: 1.05em;
	}

	@media (max-width: 768px) {
		.contact-methods {
			grid-template-columns: 1fr;
		}

		.contact-card {
			padding: 25px;
		}

		.quick-info {
			padding: 25px;
		}

		.info-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
