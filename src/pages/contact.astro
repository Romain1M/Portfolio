---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact - Romain Missoum">
	<section class="container contact-section">
		<h2>✉️ Me contacter</h2>

		<div class="contact-content">
			<div class="contact-intro">
				<p>Je suis toujours ouvert à de nouvelles opportunités et aux discussions intéressantes. N'hésitez pas à me contacter !</p>
			</div>

			<div class="contact-methods">
				<div class="contact-card linkedin">
					<div class="contact-icon">
						<svg viewBox="0 0 24 24" fill="currentColor">
							<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/>
						</svg>
					</div>
					<h3>LinkedIn</h3>
					<p>Connectons-nous pour discuter de projets et d'opportunités</p>
					<a href="https://fr.linkedin.com/in/romain-missoum-9ba32a339" target="_blank" class="contact-link">
						Visiter mon profil →
					</a>
				</div>

				<div class="contact-card email">
					<div class="contact-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<rect x="2" y="4" width="20" height="16" rx="2"/>
							<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
						</svg>
					</div>
					<h3>Email</h3>
					<p>Pour des demandes directes et des propositions</p>
					<a href="mailto:contact@example.com" class="contact-link">
						Envoyer un email
					</a>
				</div>
			</div>

			<div class="quick-info">
				<h3>📋 Informations Rapides</h3>
				<div class="info-grid">
					<div class="info-item">
						<span class="label">Âge:</span>
						<span class="value">20 ans</span>
					</div>
					<div class="info-item">
						<span class="label">Formation:</span>
						<span class="value">Bac Maths & NSI</span>
					</div>
					<div class="info-item">
						<span class="label">Spécialité:</span>
						<span class="value">Développement Web</span>
					</div>
					<div class="info-item">
						<span class="label">Langues:</span>
						<span class="value">Français, Anglais</span>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	.contact-section {
		margin-bottom: 60px;
	}

	.contact-intro {
		text-align: center;
		max-width: 700px;
		margin: 0 auto 50px;
		font-size: 1.15em;
		color: #ddd;
		line-height: 1.8;
	}

	.contact-methods {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 30px;
		margin-bottom: 60px;
	}

	.contact-card {
		background: linear-gradient(135deg, rgba(42, 42, 42, 0.6) 0%, rgba(30, 30, 30, 0.6) 100%);
		padding: 35px;
		border-radius: 12px;
		border: 2px solid transparent;
		text-align: center;
		transition: all 0.3s ease;
		backdrop-filter: blur(10px);
	}

	.contact-card:hover {
		border-color: #ffcc00;
		transform: translateY(-10px);
		box-shadow: 0 15px 40px rgba(255, 204, 0, 0.2);
	}

	.contact-icon {
		width: 70px;
		height: 70px;
		margin: 0 auto 20px;
		background: linear-gradient(135deg, #ffcc00, #ff9500);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #121212;
		font-weight: bold;
	}

	.contact-icon svg {
		width: 35px;
		height: 35px;
	}

	.contact-card h3 {
		font-size: 1.4em;
		margin-bottom: 10px;
		color: #ffcc00;
	}

	.contact-card p {
		color: #aaa;
		margin-bottom: 20px;
		line-height: 1.6;
	}

	.contact-link {
		display: inline-block;
		padding: 12px 25px;
		background: linear-gradient(135deg, #ffcc00, #ff9500);
		color: #121212;
		border-radius: 6px;
		font-weight: 500;
		transition: all 0.3s ease;
		text-decoration: none;
	}

	.contact-link:hover {
		transform: scale(1.05);
		box-shadow: 0 8px 20px rgba(255, 204, 0, 0.4);
	}

	.linkedin {
		border-top: 3px solid #0077b5;
	}

	.email {
		border-top: 3px solid #ff5733;
	}

	.quick-info {
		background: linear-gradient(135deg, rgba(255, 204, 0, 0.1) 0%, rgba(255, 149, 0, 0.05) 100%);
		padding: 35px;
		border-radius: 12px;
		border: 2px solid rgba(255, 204, 0, 0.3);
		max-width: 700px;
		margin: 0 auto;
	}

	.quick-info h3 {
		text-align: center;
		margin-bottom: 25px;
		font-size: 1.3em;
		color: #ffcc00;
	}

	.info-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 20px;
	}

	.info-item {
		background: rgba(255, 204, 0, 0.05);
		padding: 15px;
		border-radius: 8px;
		border-left: 3px solid #ffcc00;
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.info-item .label {
		color: #ffcc00;
		font-weight: 600;
		font-size: 0.9em;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.info-item .value {
		color: #ddd;
		font-size: 1.05em;
	}

	@media (max-width: 768px) {
		.contact-methods {
			grid-template-columns: 1fr;
		}

		.contact-card {
			padding: 25px;
		}

		.quick-info {
			padding: 25px;
		}

		.info-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

