---
interface Props {
  title: string;
  description: string;
  skills: string[];
  link: string;
  subtitle?: string;
  period?: string;
  context?: string;
}

const { title, description, skills, link, subtitle, period, context } = Astro.props;
---

<div class="project-card">
  <h3>{title}</h3>
  {subtitle && <p class="subtitle">{subtitle}</p>}
  {period && <p class="period">{period}</p>}
  {context && <p class="context">{context}</p>}
  <p class="description">{description}</p>
  <div class="skills-used">
    <strong>Compétences :</strong>
    {skills.map(skill => (
      <span class="skill">{skill}</span>
    ))}
  </div>
  {link !== "#" && (
    <a href={link} class="project-link">Voir le détail →</a>
  )}
</div>

<style>
  .project-card {
    background: rgba(31, 41, 55, 0.8);
    padding: 30px;
    border-radius: 12px;
    margin: 20px 0;
    transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    border: 1px solid rgba(30, 64, 175, 0.3);
    backdrop-filter: blur(10px);
    position: relative;
    overflow: hidden;
  }

  .project-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(30, 64, 175, 0.1), transparent);
    transition: left 0.5s ease;
  }

  .project-card:hover {
    transform: translateY(-8px) scale(1.02);
    border-color: rgba(30, 64, 175, 0.6);
    box-shadow: 0 16px 56px rgba(30, 64, 175, 0.25);
    background: rgba(31, 41, 55, 0.95);
  }

  h3 {
    color: var(--dk-accent);
    margin-bottom: 8px;
    font-size: 1.4em;
    font-weight: 600;
    position: relative;
    z-index: 1;
  }

  .subtitle {
    color: var(--dk-green);
    font-size: 1em;
    margin-bottom: 5px;
    position: relative;
    z-index: 1;
  }

  .period {
    color: var(--dk-muted);
    font-size: 0.9em;
    margin-bottom: 5px;
    position: relative;
    z-index: 1;
  }

  .context {
    color: var(--dk-muted);
    font-size: 0.85em;
    margin-bottom: 10px;
    position: relative;
    z-index: 1;
  }

  .description {
    margin-bottom: 15px;
    line-height: 1.6;
    color: var(--dk-text);
    position: relative;
    z-index: 1;
  }

  .skills-used {
    margin: 15px 0;
    font-size: 0.95em;
    color: var(--dk-muted);
    position: relative;
    z-index: 1;
  }

  .skill {
    display: inline-block;
    background-color: rgba(147, 197, 253, 0.15);
    color: var(--dk-accent);
    padding: 6px 12px;
    border-radius: 6px;
    margin: 5px 5px 5px 0;
    border: 1px solid rgba(147, 197, 253, 0.3);
    font-weight: 500;
    transition: all 0.2s;
  }

  .skill:hover {
    background-color: rgba(147, 197, 253, 0.25);
    border-color: var(--dk-accent);
  }

  .project-link {
    display: inline-block;
    color: var(--dk-accent);
    margin-top: 10px;
    padding: 10px 20px;
    border: 2px solid var(--dk-accent);
    border-radius: 6px;
    transition: all 0.3s;
    font-weight: 600;
    position: relative;
    z-index: 1;
  }

  .project-link:hover {
    background-color: var(--dk-accent);
    color: #0f172a;
    transform: translateX(4px);
  }
</style>
