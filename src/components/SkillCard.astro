---
interface Props {
  category: string;
  skills: string[];
}

const { category, skills } = Astro.props;
---

<div class="skill-card">
  <h3>{category}</h3>
  <div class="skill-tags">
    {skills.map(skill => (
      <span class="skill-tag">{skill}</span>
    ))}
  </div>
</div>

<style>
  .skill-card {
    background-color: #2a2a2a;
    padding: 20px;
    border-radius: 8px;
    margin: 15px 0;
    border-left: 4px solid #ffcc00;
  }

  h3 {
    color: #ffcc00;
    margin-bottom: 15px;
    font-size: 1.2em;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .skill-tag {
    background-color: #1e1e1e;
    color: #ffcc00;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 0.9em;
    border: 1px solid #ffcc00;
  }
</style>

