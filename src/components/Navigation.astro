---
const links = [
  { name: "Accueil", href: "/Portfolio/" },
  { name: "À propos", href: "/Portfolio/about" },
  { name: "Compétences", href: "/Portfolio/skills" },
  { name: "Projets", href: "/Portfolio/projects" },
];

const currentPath = Astro.url.pathname;
---

<nav class="navbar">
  <div class="nav-container">
    <div class="nav-brand">
      <a href="/Portfolio/">RM</a>
    </div>

    <button class="hamburger" id="hamburger" aria-label="Ouvrir le menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <ul class="nav-links" id="nav-menu" role="list">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class={currentPath === link.href ? "active" : ""}
          >
            {link.name}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 200;
    background: linear-gradient(135deg, rgba(0, 0, 0, 0.97) 0%, rgba(15, 23, 42, 0.97) 100%);
    backdrop-filter: blur(10px);
    border-bottom: 2px solid rgba(147, 197, 253, 0.4);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
  }

  .nav-container {
    width: 88%;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 0;
  }

  /* Brand */
  .nav-brand a {
    font-size: 1.8em;
    font-weight: bold;
    color: #e2e8f0;
    text-decoration: none;
    transition: color 0.3s ease;
    letter-spacing: 2px;
  }
  .nav-brand a:hover {
    color: #93c5fd;
  }

  /* ── Hamburger ────────────────────────────────── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 36px;
    height: 26px;
    background: none;
    border: 2px solid rgba(147, 197, 253, 0.5);
    border-radius: 6px;
    cursor: pointer;
    padding: 5px 6px;
    transition: border-color 0.2s, background 0.2s;
  }
  .hamburger:hover {
    border-color: #93c5fd;
    background: rgba(147, 197, 253, 0.08);
  }
  .hamburger span {
    display: block;
    width: 100%;
    height: 2px;
    background: #e2e8f0;
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .hamburger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .hamburger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* ── Nav links (desktop) ──────────────────────── */
  .nav-links {
    display: flex;
    list-style: none;
    gap: 30px;
    margin: 0;
    padding: 0;
  }
  .nav-links a {
    color: #94a3b8;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95em;
    position: relative;
    padding: 6px 0;
    transition: color 0.25s ease;
  }
  .nav-links a::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, #93c5fd, #6ee7b7);
    border-radius: 2px;
    transition: width 0.3s ease;
  }
  .nav-links a:hover,
  .nav-links a.active {
    color: #e2e8f0;
  }
  .nav-links a:hover::after,
  .nav-links a.active::after {
    width: 100%;
  }

  /* ── Mobile (≤ 640px) ─────────────────────────── */
  @media (max-width: 640px) {
    .hamburger {
      display: flex;
    }

    /* Le menu se positionne par rapport au viewport via fixed */
    .nav-links {
      display: none;
      flex-direction: column;
      gap: 0;
      position: fixed;
      top: 62px;          /* hauteur approximative de la navbar */
      right: 16px;
      width: 200px;
      z-index: 9999;
      background: #0a0e27;
      border: 1px solid rgba(147, 197, 253, 0.35);
      border-radius: 10px;
      padding: 6px 0;
      box-shadow: 0 16px 40px rgba(0, 0, 0, 0.7);
    }
    .nav-links.open {
      display: flex;
    }
    .nav-links li {
      width: 100%;
    }
    .nav-links a {
      display: block;
      padding: 13px 18px;
      font-size: 1em;
      color: #cbd5e1;
      border-radius: 0;
    }
    .nav-links a::after {
      display: none;
    }
    .nav-links a:hover,
    .nav-links a.active {
      color: #93c5fd;
      background: rgba(147, 197, 253, 0.1);
    }
    .nav-links li:first-child a { border-radius: 9px 9px 0 0; }
    .nav-links li:last-child  a { border-radius: 0 0 9px 9px; }
  }
</style>

<script is:inline>
  (function () {
    var btn  = document.getElementById("hamburger");
    var menu = document.getElementById("nav-menu");
    if (!btn || !menu) return;

    function closeMenu() {
      btn.setAttribute("aria-expanded", "false");
      menu.classList.remove("open");
    }

    btn.addEventListener("click", function (e) {
      e.stopPropagation();
      var isOpen = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", isOpen ? "false" : "true");
      menu.classList.toggle("open", !isOpen);
    });

    menu.querySelectorAll("a").forEach(function (a) {
      a.addEventListener("click", closeMenu);
    });

    document.addEventListener("click", function (e) {
      if (!btn.contains(e.target) && !menu.contains(e.target)) {
        closeMenu();
      }
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closeMenu();
    });
  })();
</script>
