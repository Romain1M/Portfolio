---
const currentYear = new Date().getFullYear();
---

<footer>
  <div class="container">
    <p>&copy; {currentYear} Romain Missoum. Tous droits réservés.</p>
    <div class="social-links">
      <a href="https://fr.linkedin.com/in/romain-missoum-9ba32a339" target="_blank">LinkedIn</a>
    </div>
  </div>
</footer>

<style>
  footer {
    background: #1e1e1e;
    padding: 30px 0;
    text-align: center;
    margin-top: 80px;
    border-top: 1px solid #ffcc00;
  }

  .container {
    width: 80%;
    margin: 0 auto;
    max-width: 1200px;
  }

  p {
    margin-bottom: 15px;
    color: #aaa;
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 15px;
  }

  a {
    color: #ffcc00;
    text-decoration: none;
    transition: color 0.3s;
  }

  a:hover {
    color: #ff6600;
  }
</style>

