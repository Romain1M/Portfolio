---
const currentYear = new Date().getFullYear();
---

<footer>
  <div class="container">
    <p>&copy; {currentYear} Romain Missoum. Tous droits réservés.</p>
    <div class="social-links">
      <a href="https://fr.linkedin.com/in/romain-missoum-9ba32a339" target="_blank">LinkedIn</a>
      <a href="https://github.com/Romain1M" target="_blank">GitHub</a>
    </div>
  </div>
</footer>

<style>
  footer {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(8px);
    padding: 30px 0;
    text-align: center;
    margin-top: 56px;
    border-top: 1px solid #dbe3ee;
  }

  .container {
    width: 80%;
    margin: 0 auto;
    max-width: 1200px;
  }

  p {
    margin-bottom: 15px;
    color: #475569;
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 15px;
  }

  a {
    color: #2563eb;
    text-decoration: none;
    transition: color 0.3s;
  }

  a:hover {
    color: #1d4ed8;
  }
</style>
