---
const currentYear = new Date().getFullYear();
---

<footer>
  <div class="container">
    <nav class="footer-nav" aria-label="Navigation principale">
      <a href="./">Accueil</a>
      <a href="./about">À propos</a>
      <a href="./skills">Compétences</a>
      <a href="./projects">Projets</a>
    </nav>
    <div class="social-links">
      <a href="https://fr.linkedin.com/in/romain-missoum-9ba32a339" target="_blank" rel="noopener">LinkedIn</a>
      <a href="https://github.com/Romain1M" target="_blank" rel="noopener">GitHub</a>
    </div>
    <p>&copy; {currentYear} Romain Missoum</p>
  </div>
</footer>

<style>
  footer {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.97) 0%, rgba(0, 0, 0, 0.97) 100%);
    backdrop-filter: blur(8px);
    padding: 40px 0 30px;
    text-align: center;
    margin-top: 56px;
    border-top: 2px solid rgba(147, 197, 253, 0.3);
  }

  .container {
    width: 88%;
    margin: 0 auto;
    max-width: 1200px;
  }

  .footer-nav {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8px 24px;
    margin-bottom: 20px;
  }

  .footer-nav a {
    color: #cbd5e1;
    font-size: 0.9em;
    font-weight: 500;
    text-decoration: none;
    padding: 4px 0;
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }

  .footer-nav a:hover {
    color: #93c5fd;
    border-bottom-color: #93c5fd;
    transform: none;
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 20px;
  }

  .social-links a {
    color: #93c5fd;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9em;
    transition: color 0.2s;
  }

  .social-links a:hover {
    color: #6ee7b7;
  }

  p {
    color: #475569;
    font-size: 0.82em;
    margin: 0;
  }
</style>
