---
const currentAge = 20;
const title = "Romain Missoum";
const subtitle = "Étudiant BUT Informatique";
---

<header>
  <div class="container header-content">
    <div class="header-text">
      <h1>{title}</h1>
      <p class="subtitle">{subtitle}</p>
      <p class="status">{currentAge} ans • Etudiant en informatique</p>
      <p class="bio">Curieux, autonome, et toujours en train de casser quelque chose pour comprendre comment ça marche</p>
    </div>
  </div>
</header>

<style>
  header {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.95) 0%, rgba(0, 0, 0, 0.95) 100%);
    backdrop-filter: blur(8px);
    padding: 72px 0 56px;
    border-bottom: 2px solid var(--primary);
    position: relative;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(30, 64, 175, 0.15);
  }

  header::before {
    content: "";
    position: absolute;
    top: -50%;
    right: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(30, 64, 175, 0.15) 0%, transparent 70%);
    border-radius: 50%;
  }

  .container {
    width: 80%;
    margin: 0 auto;
    max-width: 1200px;
    position: relative;
    z-index: 1;
  }

  .header-content {
    text-align: center;
  }

  h1 {
    margin-bottom: 15px;
    font-weight: 700;
    background: linear-gradient(135deg, var(--dk-accent), var(--dk-green));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-size: 1.35em;
    color: var(--dk-accent);
    margin-bottom: 15px;
    font-weight: 500;
  }

  .status {
    font-size: 1.05em;
    color: var(--dk-muted);
    margin: 10px 0;
  }

  .bio {
    font-size: 1.05em;
    color: var(--dk-muted);
    margin-top: 20px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 768px) {
    .subtitle {
      font-size: 1.05em;
    }

    header {
      padding: 50px 0 40px;
    }

    header::before {
      width: 300px;
      height: 300px;
    }
  }
</style>
